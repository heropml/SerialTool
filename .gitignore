# Python 字节码缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# PyInstaller 打包产物 — 不入库（体积大、每次打包都变）；安装包改由 GitHub Release 分发
build/
build_onefile/
dist/
dist_onefile/
installer/
# .spec 文件每次 PyInstaller 自动重新生成（build.bat 用 CLI 参数构造）
*.spec

# 运行时用户配置（每台机器不同）
settings.ini

# pycdc Python 反编译器（恢复 main.py 时临时用过，SerialTool 编译/运行不需要）
tools/

# 临时/恢复残留
_strings.txt
recovered_pycdc.py

# venv
.venv/
.venv-linux/

# 编辑器 / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
desktop.ini
